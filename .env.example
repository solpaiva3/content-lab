DATABASE_URL="file:./dev.db"

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Figma integration
# Access token — https://www.figma.com/settings → Personal access tokens
FIGMA_ACCESS_TOKEN=

# File key — the alphanumeric segment in the Figma file URL:
# https://www.figma.com/design/<FILE_KEY>/...
FIGMA_FILE_KEY=

# Frame node ID — right-click the target frame in Figma → Copy link
# The link looks like: ...?node-id=4-32&t=abc123
# Use only the node-id part: 4-32
FIGMA_FRAME_ID=
