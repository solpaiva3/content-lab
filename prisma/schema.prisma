generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id           String   @id @default(cuid())
  name         String
  sector       String
  personality  String
  pillars      String
  toneNotes    String?
  toneOfVoice  String?
  colors       String
  fonts        String
  fontFiles    String?
  logoUrl      String?
  logoVariants String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId       String   @default("") // which CarouselTemplate was used
  slides           String   @default("[]") // JSON array of CarouselSlide
  title            String   @default("") // hook slide title — for Figma plugin compat
  subtitle         String   @default("") // hook slide subtitle — for Figma plugin compat
  body             String   @default("") // insight slide body — for Figma plugin compat
  caption          String   @default("")
  visualDescription String  @default("")
  logoUsage        String   @default("")
  createdAt        DateTime @default(now())
}
